<configuration name="switch.conf" description="Core Configuration">
  <settings>
    
    <param name="max-sessions" value="${MAX_SESSIONS:-10000}"/>
    <param name="sessions-per-second" value="1000"/>
    <param name="min-idle-cpu" value="10"/>

    
    <param name="loglevel" value="warning"/>
    <param name="log-uuid" value="true"/>

    
    <param name="rtp-start-port" value="16384"/>
    <param name="rtp-end-port" value="32768"/>

    
    <param name="core-db-dsn" value=""/>
    <param name="event-heartbeat-interval" value="30"/>
  </settings>
</configuration>
